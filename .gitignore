*.aar

# Sensitive credentials
google-services.json
*.keystore
*.jks

# Gradle wrapper - keep these tracked
!gradle/wrapper/gradle-wrapper.properties
!gradlew
!gradlew.bat

# KSP/Room schema - KEEP tracked for migration history
# (don't add app/schemas/ to gitignore)

# IDE temp files
*.swp
*.swo
*~
.vscode/
*.sublime-workspace

# Test coverage
coverage/
*.lcov

# Runtime files
*.log

# Build caches
.externalNativeBuild
.cxx
/captures
