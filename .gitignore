.gradle/
build/
app/build/
*/build/

# Android Studio IDE files
.idea/
!.idea/codeStyles/
!.idea/inspectionProfiles/
*.iml
*.iws
*.ipr

# Local configuration files - CRITICAL: contains sensitive API keys
local.properties

# OS files
.DS_Store
Thumbs.db

# Kotlin/Java compiled files
*.class
*.jar
